# ─────────────────────────────────────────────────────────
# DATABASE (PostgreSQL obrigatório para Vercel/produção)
# Use Neon (gratuito): https://neon.tech
#   1. Crie um projeto no Neon
#   2. Copie a "Connection string" pooled → DATABASE_URL
#   3. Copie a "Connection string" direct → DIRECT_URL
# ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─────────────────────────────────────────────────────────
# ANTHROPIC API (opcional — para importar PDF de concorrente)
# ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seu-app.vercel.app"
